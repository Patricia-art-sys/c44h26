<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity" >

    <TextView
        android:id="@+id/nomAPP"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.3"
        android:background="#313131"
        android:gravity="center"
        android:text="Lyne App Dessin"
        android:textColor="#EBD8D8"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/couleurs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.6"
        android:background="#A99999"
        android:gravity="center_horizontal|center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/Group"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:padding="0dp"
            app:selectionRequired="true"
            app:singleSelection="true">


            <com.google.android.material.chip.Chip
                android:id="@+id/colorRed"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="5dp"
                android:layout_weight="1"
                android:backgroundTint="#490202"
                android:checkable="true"
                android:tag="#490202"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/colorGreen"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:backgroundTint="#65BC0A"
                android:checkable="true"
                android:tag="#65BC0A"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/colorYellow"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:backgroundTint="#FAE634"
                android:checkable="true"
                android:tag="#FAE634"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/colorBlue"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:backgroundTint="#1B5B8E"
                android:checkable="true"
                android:tag="#1B5B8E"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/colorBlack"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:backgroundTint="#050505"
                android:checkable="true"
                android:tag="#050505"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/colorGay"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:backgroundTint="#858282"
                android:checkable="true"
                android:tag="#858282"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/colorPurple"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:backgroundTint="#9C27B0"
                android:checkable="true"
                android:tag="#9C27B0"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/colorPink"
                android:layout_width="40dp"
                android:layout_height="56dp"
                android:layout_marginLeft="2dp"
                android:layout_weight="1"
                android:backgroundTint="#D783A1"
                android:checkable="true"
                android:tag="#D783A1"
                app:chipCornerRadius="60dp"
                app:chipIcon="@drawable/effets"
                app:chipStrokeColor="@color/effetschip"
                app:chipStrokeWidth="3dp" />
        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/parent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="4"
        android:background="#FAF0E6">

    </androidx.constraintlayout.widget.ConstraintLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/outils"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_horizontal|center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/crayon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="crayon"
                app:srcCompat="@drawable/crayon" />

            <ImageButton
                android:id="@+id/efface"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="efface"
                app:srcCompat="@drawable/efface" />

            <ImageButton
                android:id="@+id/cercle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="cercle"
                app:srcCompat="@drawable/cercle" />

            <ImageButton
                android:id="@+id/triangle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="triangle"
                app:srcCompat="@drawable/triangle" />

            <ImageButton
                android:id="@+id/rectangle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="rectangle"
                app:srcCompat="@drawable/rectangle" />

            <ImageButton
                android:id="@+id/largeurTrait"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="largeurTrait"
                app:srcCompat="@drawable/largeur_trait" />

            <ImageButton
                android:id="@+id/pipette"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="pipette"
                app:srcCompat="@drawable/pipette" />

            <ImageButton
                android:id="@+id/remplissage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="remplissage"
                app:srcCompat="@drawable/remplir" />

            <ImageButton
                android:id="@+id/undo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="undo"
                app:srcCompat="@drawable/undo" />

            <ImageButton
                android:id="@+id/redo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="redo"
                app:srcCompat="@drawable/redo" />

            <ImageButton
                android:id="@+id/enregistrer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:tag="enregistrer"
                app:srcCompat="@drawable/enregistrer" />

        </LinearLayout>
    </HorizontalScrollView>

</LinearLayout>